APP_ENV=development
APP_PORT=8080
APP_LOG_LEVEL=info

DATABASE_URL=postgres://sadiqarogundade:ServBay.dev@localhost:5432/pgdp?sslmode=disable
REDIS_URL=redis://localhost:6379/0

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=pgdp-docs
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# SMTP — outbound mail for member / vendor / agent invites.
#
# Local dev: leave as localhost:1025 and run MailHog
#   docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog
#
# Real delivery (Mailgun): the values live in this repo's GitHub Actions
# secrets (MAILGUN_SMTP_HOST / PORT / USER / PASS / MAILGUN_FROM). The running
# API can't read GitHub secrets directly — those are write-only and only
# accessible inside CI runners. Copy them once into your local .env (or your
# host's secret manager) under the keys below.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@pgdp.local

GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

ALLOWED_ORIGINS=http://localhost:5173
